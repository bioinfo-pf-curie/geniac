set(CMAKE_INSTALL_PREFIX "/usr/local" CACHE PATH "Install path prefix, prepended onto install directories.")
set(ap_annotation_path "" CACHE STRING "Path to the annotations. A symlink annotations with the given target will be created. Default is empty.")
set(ap_check_config_file_from_source "ON" CACHE BOOL "Check if the nextflow config files generated by geniac are present in the source directory. If this is the case, they are compared with those automatically generated by geniac during the build process. If one is different an ERROR is thrown. Default is ON.")
set(ap_conda_release "24.11.3-2" CACHE STRING "When building the docker/singularity images, geniac bootstraps from docker containers available on the docker hub registry https://hub.docker.com/u/4geniac. When a tool is installed with Conda, the container obviously needs Conda. Therefore, this variable defines which Conda release to use from https://hub.docker.com/u/4geniac. For details, about the docker containers see https://github.com/bioinfo-pf-curie/4geniac. Default is 24.11.3-2.")
set(ap_container_list "" CACHE STRING "Provide PATH to a text file which contains the list of tool labels for which the containers will be built. This makes it possible to build only a subset of containers instead of building all the containers for all the tools.")
set(ap_docker_registry "4geniac/" CACHE STRING "Docker registry used to build the containers from recipes automatically generated by geniac. Default is 4geniac/ (see https://hub.docker.com/u/4geniac and https://github.com/bioinfo-pf-curie/4geniac).")
set(ap_docker_registry_push_repo "" CACHE STRING "Docker registry used to push the containers automatically generated by geniac. Default is empty string ''.")
set(ap_docker_registry_push_user "" CACHE STRING "User to connect to the Docker registry used to push the containers automatically generated by geniac. The user password should be set in your environment using the comnmand 'nextflow secrets set DOCKER_REGISTRY_PUSH_USER your_password' Default is empty string ''.")
set(ap_install_docker_images "OFF" CACHE BOOL "Generate and install Dockerfiles and docker images. Default is OFF.")
set(ap_install_docker_recipes "OFF" CACHE BOOL "Generate and install Dockerfiles. Default is OFF.")
set(ap_install_podman_images "OFF" CACHE BOOL "Generate and install Dockerfiles and podman images. Default is OFF.")
set(ap_install_podman_recipes "OFF" CACHE BOOL "Generate and install Dockerfiles. Default is OFF.")
set(ap_install_singularity_images "OFF" CACHE BOOL "Generate and install Singularity def files and images. Default is OFF.")
set(ap_install_singularity_images_from_registry "OFF" CACHE BOOL "Generate and install Singularity def files and images. The images are built using the containers avaibable on the registry defined by the variable ap_docker_push_registry. This requires that geniac has been previously run using both ap_install_docker_images and ap_push_images options. Default is OFF.")
set(ap_install_singularity_recipes "OFF" CACHE BOOL "Generate and install singularity def files. Default is OFF.")
set(ap_keep_envyml_from_source "OFF" CACHE BOOL "If present, the file environment.yml will be installed instead of the file automatically generated by geniac. Default is OFF.")
set(ap_linux_distro "almalinux:9.5" CACHE STRING "When building the docker/singularity images, geniac bootstraps from docker containers available on the docker hub registry https://hub.docker.com/u/4geniac. This variable defines which Linux distro (i.e. which repository) and which version (i.e. which tag) to use from https://hub.docker.com/u/4geniac. For details, about the docker containers see https://github.com/bioinfo-pf-curie/4geniac. Default is almalinux:9.5.")
set(ap_mount_dir "" CACHE STRING "Option is deprecated.")
set(ap_nf_executor "slurm" CACHE STRING "executor used by nextflow (e.g. pbs, slurm, etc.). Default is slurm")
set(ap_no_git "OFF" CACHE BOOL "Add the option to deploy without git retrieving informations. Default is OFF.")
set(ap_push_images "OFF" CACHE BOOL "Push images on the container registry defined in the variable ap_docker_registry_push_repo. Push will be effective whenever ap_install_docker_images of ap_install_podman_images are set to ON. Default is OFF.")
set(ap_singularity_build_options "" CACHE STRING "Allow to pass specific options when building singularity images. (e.g. --fakeroot). Default is empty.")
set(ap_singularity_image_path "" CACHE STRING "Path to the singularity images. A symlink containers/singularity with the given target will be created. Default is empty.")
